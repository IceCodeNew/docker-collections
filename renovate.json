{
  "forkProcessing": "enabled",

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.markitdown_version$/"],
      "matchStrings": ["(?<currentValue>.*?)\\n"],
      "depNameTemplate": "markitdown",
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github\\/workflows\\/.+\\.ya?ml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))? packageName=(?<packageName>.+?)(?: versioning=(?<versioning>[a-z-]+?))?\\s+ref: ['\"]?(?<currentValue>[^'\"]+)['\"]?"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github\\/workflows\\/.+\\.ya?ml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))? packageName=(?<packageName>.+?)(?: versioning=(?<versioning>[a-z-]+?))?\\s+[A-Z0-9_]+_VERSION: ['\"]?(?<currentValue>[^'\"\\s]+)['\"]?"
      ]
    },
    {
      "customType": "regex",
      "description": "Update _VERSION variables in Dockerfiles",
      "managerFilePatterns": [
        "/(^|/|\\.)[dD]ockerfile$/",
        "/(^|/)[dD]ockerfile\\.[^/]*$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))? packageName=(?<packageName>.+?)(?: versioning=(?<versioning>[a-z-]+?))?\\s(?:ENV|ARG) .+?_VERSION=(?<currentValue>[^\\s]+)"
      ]
    }
  ],
  "extends": [
    "config:best-practices",
    "group:allNonMajor",
    "group:githubArtifactActions",
    "group:linters",
    "schedule:automergeNonOfficeHours",
    "security:openssf-scorecard"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["*"],
      "minimumReleaseAge": "3 days",
      "internalChecksFilter": "strict"
    },
    {
      "matchPackageNames": ["aws/aws-lc"],
      "allowedVersions": "!/alpha|beta|fips|rc|test|week/i"
    },
    {
      "matchPackageNames": ["iproute2/iproute2"],
      "allowedVersions": "!/alpha|beta|fips|rc|test|week/i"
    },
    {
      "matchPackageNames": ["library/haproxy"],
      "allowedVersions": "/^[0-9]+\\.[0-9]*[02468]$/"
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "matchUpdateTypes": ["digest"],
      "matchDatasources": ["docker"],
      "minimumReleaseAge": null,
      "ignoreTests": true,
      "automerge": true
    },
    {
      "description": "Batch repository-produced image digest updates to reduce self-triggering build loops.",
      "matchUpdateTypes": ["digest"],
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/\\/icecodexi\\//"],
      "minimumReleaseAge": "12 hours",
      "schedule": ["after 12am and before 1am", "after 12pm and before 1pm"],
      "automerge": true
    }
  ],
  "automergeType": "branch",
  "timezone": "Asia/Shanghai"
}
